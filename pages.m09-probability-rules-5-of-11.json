y":"fazy0P7065"}],"key":"kDhhjeK9B0"},{"type":"paragraph","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"Using a Venn diagram, we can visualize “A and B,” which is represented by the overlap between events A and B:","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"uPR7Xr3xgF"}],"key":"ghH0dwZgjY"},{"type":"container","kind":"figure","children":[{"type":"image","url":"/build/image019-ed200f95070955bec3a5a7418d5f8185.gif","alt":"A rectangle represents the entire sample space. Inside this rectangle are two circles, one for the occurrences in A and one for the occurrences in B. These two circles partially overlap. The area in the overlap contains the ocurrences for A and B.","key":"j0FBBSgZUR","urlSource":"images/image019.gif"},{"type":"caption","children":[{"type":"paragraph","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"A rectangle represents the entire sample space. Inside this rectangle are two circles, one for the occurrences in A and one for the occurrences in B. These two circles partially overlap. The area in the overlap contains the ocurrences for A and B.","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"ODgafEEnsv"}],"key":"JvIAmpLHkw"}],"key":"Abym3JLrkb"}],"enumerator":"1","key":"O8Ri0xfK6L"},{"type":"heading","depth":2,"position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"Comment","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"ss3DDrWAAO"}],"identifier":"comment","label":"Comment","html_id":"comment","implicit":true,"key":"J7DCseP8Ds"},{"type":"paragraph","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"text","value":"There is one special case for which we know what P(A and B) equals without applying any rule.","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"pvIUvBeol9"}],"key":"Jk1sJ21Hon"},{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Note","key":"YZlFwnn3iG"}],"key":"NFllkjAUOX"},{"type":"code","lang":"","value":"**Learn By Doing**\n\n*(Interactive activity — available in the OLI platform)*","position":{"start":{"line":26,"column":1},"end":{"line":28,"column":1}},"key":"FjibbnCpgU"}],"key":"TevPJl1aJe"},{"type":"paragraph","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"children":[{"type":"text","value":"So, if events ","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"MDwPzJb9fP"},{"type":"emphasis","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"children":[{"type":"text","value":"A and B are disjoint","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"TTuMrah0oG"}],"key":"uPjpSEqlsX"},{"type":"text","value":", then (by definition) ","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"bnpUECp8WU"},{"type":"emphasis","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"children":[{"type":"text","value":"P(A and B)= 0.","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"lbAH9w29GQ"}],"key":"vquB2qYHMA"},{"type":"text","value":" But what if the events are not disjoint?","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"WWyBLSiJoc"}],"key":"ApA7zxyxZt"},{"type":"paragraph","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"text","value":"Recall that rule 4, the Addition Rule, has two versions. One is restricted to disjoint events, which we’ve already covered, and we’ll deal with the more general version later in this module. The same is true of rule 5. Rule 5 has two versions. The version we’ll present here is restricted to a special case that we’ll now discuss, and there is a more general version that we’ll present in the next module.","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"UHSlm23hIG"}],"key":"uqoONpe7Xp"},{"type":"paragraph","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"children":[{"type":"text","value":"The version of rule 5 that will be presented here applies to the special case in which the two events are ","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"aUOjtiG0Dt"},{"type":"emphasis","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"children":[{"type":"text","value":"independent","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"KrDOrJeTAy"}],"key":"zr4Ddzgp7Y"},{"type":"text","value":" of each other.","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"GD6APM4IBH"}],"key":"QTNij7ieij"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Definition: independent","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"key":"C0NVeqaN0g"}],"key":"Zk3lpfoGfW"},{"type":"code","lang":"","value":"Two events A and B are said to be *independent* if\n                        the\n                        fact\n                        that\n                        one event has occurred *does not affect* the probability that the\n                        other event\n                        will\n                        occur.\n                        If whether\n                        or not\n                        one event occurs *does affect* the probability that\n                        the other event\n                        will\n                        occur,\n                        then the two events are said to be *dependent.*","position":{"start":{"line":38,"column":1},"end":{"line":52,"column":1}},"key":"X8Ncw2HAFV"}],"key":"BOc1rTOMPp"},{"type":"paragraph","position":{"start":{"line":55,"column":1},"end":{"line":55,"column":1}},"children":[{"type":"text","value":"Here are a few examples:","position":{"start":{"line":55,"column":1},"end":{"line":55,"column":1}},"key":"C6RmUZiL3l"}],"key":"zonm9WCJQn"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Example","position":{"start":{"line":57,"column":1},"end":{"line":57,"column":1}},"key":"gDICQP16vg"}],"key":"BOt2QNFtUK"},{"type":"code","lang":"","value":"A woman's pocket contains two quarters and two nickels. She randomly extracts one of the coins and, after looking at it, replaces it before picking a second coin.\n\nLet Q1 be the event that the first coin is a quarter and Q2 be the event that the second coin is a quarter.\n\nAre Q1 and Q2 independent events? *Yes.* Why?\n\nSince the first coin that was selected is *replaced*, whether or not Q1 occurred (i.e., whether the first coin was a quarter) has no effect on the probability that the second coin will be a quarter, P(Q2). In either case (whether Q1 occurred or not), when she is selecting the second coin, she has in her pocket:\n\n```{figure} images/image020.gif\n:alt: The coins in the woman's pocket. There are 2 Quarters and 2 Nickels.\n\nThe coins in the woman's pocket. There are 2 Quarters and 2 Nickels.\n```\n\nand therefore the P(Q2) = 2/4 = 1/2 regardless of whether Q1 occurred.","position":{"start":{"line":58,"column":1},"end":{"line":72,"column":1}},"key":"Q2lbGKwE4n"}],"key":"PROFWA6I9P"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Example","position":{"start":{"line":75,"column":1},"end":{"line":75,"column":1}},"key":"p9C8OAln0A"}],"key":"DA1c8vcljk"},{"type":"code","lang":"","value":"A woman's pocket contains two quarters and two nickels. She randomly extracts one of the coins, and *without placing* it back into her pocket, she picks a second coin. As before, let Q1 be the event that the first coin is a quarter, and Q2 be the event that the second coin is a quarter.\n\nAre Q1 and Q2 independent events? *No.* Q1 and Q2 are *not independent*. They are *dependent.* Why?\n\nSince the first coin that was selected is *not replaced,* whether Q1 occurred (i.e., whether the first coin was a quarter) *does affect* the probability that the second coin is a quarter, P(Q2).\n\nIf Q1 occurred (i.e., the first coin was a quarter), then when the woman is selecting the second coin, she has in her pocket:\n\n```{figure} images/image021.gif\n:alt: One Quarter and Two Nickels\n\nOne Quarter and Two Nickels\n```\n\nIn this case, P(Q2) = 1/3. However, if Q1 has not occurred (i.e., the first coin was not a quarter, but a nickel), then when the woman is selecting the second coin, she has in her pocket:\n\n```{figure} images/image022.gif\n:alt: Two Quarters and One Nickel.\n\nTwo Quarters and One Nickel.\n```\n\nIn this case, P(Q2) = 2/3.\n\nIn these last two examples, we could actually have done some calculation in order to check whether or not the two events are independent or not. Sometimes we can just use common sense to guide us as to whether two events are independent. Here is an example.","position":{"start":{"line":76,"column":1},"end":{"line":100,"column":1}},"key":"AAH9R74DVR"}],"key":"GnPDfhXbqx"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Example","position":{"start":{"line":103,"column":1},"end":{"line":103,"column":1}},"key":"zDQKrOqHTN"}],"key":"NQNpD13ZtX"},{"type":"code","lang":"","value":"A family has 4 children, two of whom are selected at random. Let B1 be the event that one child has blue eyes, and B2 be the event that the other chosen child has blue eyes. In this case, B1 and B2 are not independent, since we know that eye color is hereditary, so whether or not one child is blue-eyed will increase or decrease the chances that the other child has blue eyes, respectively.","position":{"start":{"line":104,"column":1},"end":{"line":104,"column":1}},"key":"Ws0toxXpsv"}],"key":"p39v7SNgZG"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Example","position":{"start":{"line":107,"column":1},"end":{"line":107,"column":1}},"key":"hQfblv7XAL"}],"key":"yNmw2NR6t0"},{"type":"code","lang":"","value":"Two people are selected at random from all people in the United States. Let B1 be the event that one of the people has blue eyes and B2 be the event that the other person has blue eyes. In this case, since they were chosen at random, whether one of them has blue eyes has no effect on the likelihood that the other one has blue eyes, and therefore B1 and B2 are independent. On the other hand ...","position":{"start":{"line":108,"column":1},"end":{"line":108,"column":1}},"key":"PR2AAKa2P6"}],"key":"NreFBurs4d"},{"type":"paragraph","position":{"start":{"line":111,"column":1},"end":{"line":111,"column":1}},"children":[{"type":"emphasis","position":{"start":{"line":111,"column":1},"end":{"line":111,"column":1}},"children":[{"type":"text","value":"Note:","position":{"start":{"line":111,"column":1},"end":{"line":111,"column":1}},"key":"OGDD1aW88r"}],"key":"Lp643QVJBS"}],"key":"LDn9rP1KNs"},{"type":"paragraph","position":{"start":{"line":113,"column":1},"end":{"line":113,"column":1}},"children":[{"type":"text","value":"We can generalize what we learned in the last example and say that when two individuals are selected at random from a large population (like in the example, the entire U.S.) any event associated with one individual is independent of any event associated with the other individual. The fact that the two are chosen from a large population is key to the independence.","position":{"start":{"line":113,"column":1},"end":{"line":113,"column":1}},"key":"udG8VIB94a"}],"key":"UPHbZwoGTB"},{"type":"paragraph","position":{"start":{"line":115,"column":1},"end":{"line":115,"column":1}},"children":[{"type":"text","value":"If we were to change the example to: There are 10 people in a room, 4 of which have blue eyes. Two people are chosen at random. Let B1 be the event that the first person has blue eyes and let B2 be the event that the second person has blue eyes. In this case, since the two are chosen from a group of only 10 (rather than a large population) the events B1 and B2 are not independent. Clearly, whether or not the first person has blue eyes (i.e., whether or not B1 occurs) does have an effect on whether B2 occurs. You will get more practice on this point in the activities below the next comment.","position":{"start":{"line":115,"column":1},"end":{"line":115,"column":1}},"key":"Yx14a5ZyvZ"}],"key":"sABiNB9Kmg"},{"type":"heading","depth":2,"position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"children":[{"type":"text","value":"Comment","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"key":"vd7IjYK4CI"}],"identifier":"comment","label":"Comment","html_id":"comment-1","implicit":true,"key":"VNlztaqDOO"},{"type":"paragraph","position":{"start":{"line":119,"column":1},"end":{"line":119,"column":1}},"children":[{"type":"text","value":"It is quite common for students to initially get confused about the distinction between the idea of ","position":{"start":{"line":119,"column":1},"end":{"line":119,"column":1}},"key":"MwoErExkHL"},{"type":"emphasis","position":{"start":{"line":119,"column":1},"end":{"line":119,"column":1}},"children":[{"type":"text","value":"disjoint events","position":{"start":{"line":119,"column":1},"end":{"line":119,"column":1}},"key":"T42fhzPQ75"}],"key":"jfcTsiLEfe"},{"type":"text","value":" and the idea of ","position":{"start":{"line":119,"column":1},"end":{"line":119,"column":1}},"key":"GBet0KmcrP"},{"type":"emphasis","position":{"start":{"line":119,"column":1},"end":{"line":119,"column":1}},"children":[{"type":"text","value":"independent events","position":{"start":{"line":119,"column":1},"end":{"line":119,"column":1}},"key":"Vcwfb1zOMo"}],"key":"xhGS4Zt3Mm"},{"type":"text","value":". The purpose of this comment (and the activity that follows it) is to help students develop more understanding about these very different ideas.","position":{"start":{"line":119,"column":1},"end":{"line":119,"column":1}},"key":"fcjNrLPRgj"}],"key":"x491jSjGTg"},{"type":"paragraph","position":{"start":{"line":121,"column":1},"end":{"line":121,"column":1}},"children":[{"type":"text","value":"The idea of ","position":{"start":{"line":121,"column":1},"end":{"line":121,"column":1}},"key":"wJCZJtDyOx"},{"type":"emphasis","position":{"start":{"line":121,"column":1},"end":{"line":121,"column":1}},"children":[{"type":"text","value":"disjoint events","position":{"start":{"line":121,"column":1},"end":{"line":121,"column":1}},"key":"Dq0A0uKQQv"}],"key":"Ms661QZXC4"},{"type":"text","value":" is about whether or not it is possible for the events to occur at the same time (see the examples on page 3 of the Probability Rules section).","position":{"start":{"line":121,"column":1},"end":{"line":121,"column":1}},"key":"yOzwUsucdt"}],"key":"DydyaYwNnp"},{"type":"paragraph","position":{"start":{"line":123,"column":1},"end":{"line":123,"column":1}},"children":[{"type":"text","value":"The idea of ","position":{"start":{"line":123,"column":1},"end":{"line":123,"column":1}},"key":"elQuNiB76B"},{"type":"emphasis","position":{"start":{"line":123,"column":1},"end":{"line":123,"column":1}},"children":[{"type":"text","value":"independent events","position":{"start":{"line":123,"column":1},"end":{"line":123,"column":1}},"key":"dz21vkNkQe"}],"key":"sG8vbakuNu"},{"type":"text","value":" is about whether or not the events affect each other in the sense that the occurrence of one event affects the probability of the occurrence of the other (see the examples above).","position":{"start":{"line":123,"column":1},"end":{"line":123,"column":1}},"key":"WCijCTfhH1"}],"key":"hC2C5KyDiT"},{"type":"paragraph","position":{"start":{"line":125,"column":1},"end":{"line":125,"column":1}},