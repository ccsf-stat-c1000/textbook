":1},"end":{"line":64,"column":1}},"key":"IGPfzuixEQ"}],"key":"stfDM7nXPN"},{"type":"paragraph","position":{"start":{"line":67,"column":1},"end":{"line":67,"column":1}},"children":[{"type":"emphasis","position":{"start":{"line":67,"column":1},"end":{"line":67,"column":1}},"children":[{"type":"text","value":"Did You Get It?","position":{"start":{"line":67,"column":1},"end":{"line":67,"column":1}},"key":"kgrPLXzxNL"}],"key":"YZASZPDorV"},{"type":"text","value":" If so, then go ahead and move on. If not, then click the link below for some additional practice.","position":{"start":{"line":67,"column":1},"end":{"line":67,"column":1}},"key":"NwhgonfYJQ"}],"key":"aihvcXAowX"},{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Note","key":"Fnl7onUNIZ"}],"key":"yEe5tPgfHW"},{"type":"code","lang":"","value":"**Sectionnest**\n\nHypothesis Testing for the Population Mean (Extra Problem)\n\n*(Interactive activity — available in the OLI platform)*","position":{"start":{"line":70,"column":1},"end":{"line":74,"column":1}},"key":"uRv5LBi8B0"}],"key":"sl6kjBo67w"},{"type":"heading","depth":2,"position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"children":[{"type":"text","value":"Comment","position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"key":"TyQM7en9Ql"}],"identifier":"comment","label":"Comment","html_id":"comment","implicit":true,"key":"Aw4A5VDEOm"},{"type":"paragraph","position":{"start":{"line":79,"column":1},"end":{"line":79,"column":1}},"children":[{"type":"text","value":"Beyond using the confidence interval as a quick way to carry out the two-sided test, the confidence interval can provide insight into the actual value of the population mean if H~o~ is rejected. In the concentration level example, H~o~ was rejected, and all we could conclude about the mean concentration level of the entire shipment, μ, was that it was not 250. The 95% confidence interval for μ (244.6, 249.4) gives us an idea of what plausible values for μ would be. In particular, we can conclude that since the confidence interval lies below 250, at least a large portion of the shipment contains medication that is ineffective.","position":{"start":{"line":79,"column":1},"end":{"line":79,"column":1}},"key":"zpUNgL7XRo"}],"key":"B80de7XYhz"},{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Note","key":"af6MjXvsn0"}],"key":"pWDwaptlKQ"},{"type":"code","lang":"","value":"**Learn By Doing**\n\nHypothesis Testing for the Population Mean\n\n*(Interactive activity — available in the OLI platform)*","position":{"start":{"line":82,"column":1},"end":{"line":86,"column":1}},"key":"j1FBBHg1gm"}],"key":"AKbUG77nKt"},{"type":"paragraph","position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"children":[{"type":"emphasis","position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"children":[{"type":"text","value":"Do you feel that you understand this concept?","position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"key":"LkJwqq5wPO"}],"key":"IXUT1WKxst"},{"type":"text","value":" If so, then go ahead and move on. If not, then click the link below for some additional practice.","position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"key":"yucylIekpJ"}],"key":"belIJY7lGX"},{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Note","key":"tdqeLyt9Fv"}],"key":"HmsDtUZAXs"},{"type":"code","lang":"","value":"**Learn By Doing**\n\nHypothesis Testing for the Population Mean (Extra Problems)\n\n*(Interactive activity — available in the OLI platform)*","position":{"start":{"line":92,"column":1},"end":{"line":96,"column":1}},"key":"WgG3MtyzL5"}],"key":"no1mB6n0H8"},{"type":"paragraph","position":{"start":{"line":99,"column":1},"end":{"line":99,"column":1}},"children":[{"type":"text","value":"We are done with the case where the population standard deviation, σ, is known. We now move on to the more common case where σ is unknown.","position":{"start":{"line":99,"column":1},"end":{"line":99,"column":1}},"key":"hyRH0RVLx7"}],"key":"eQJ3kTC4h3"}],"key":"qK6PqDLbbl"}],"key":"cck5xlnlCR"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Hypothesis Testing for the Population Mean (4 of 9)","url":"/pages/m15-hypothesis-testing-for-the-population-mean-4-o","group":"Unit 5: Inference"},"next":{"title":"Hypothesis Testing for the Population Mean (6 of 9)","url":"/pages/m15-hypothesis-testing-for-the-population-mean-6-o","group":"Unit 5: Inference"}}},"domain":"http://localhost:3002"}