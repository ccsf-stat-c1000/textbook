":"listItem","spread":true,"position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"There are “many” binomial random variables, depending on the number of trials (n) and the probability of success (p).","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"key":"A6yDOgHzs3"}],"key":"bblxZ07vWD"}],"key":"nvUmQ1lVIf"},{"type":"listItem","spread":true,"position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"The probability distribution of the binomial random variable is given in the form of a formula and can be used to find probabilities. Technology can be used as well.","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"NHZLSCsG0p"}],"key":"spVXqXyeMf"}],"key":"BrL4Hw6i4k"},{"type":"listItem","spread":true,"position":{"start":{"line":43,"column":1},"end":{"line":44,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"The mean and standard deviation of a binomial random variable can be easily found using short-cut formulas.","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"key":"ByM3BSRnKu"}],"key":"MNQ2iPIeT5"}],"key":"K0ZTeAlvve"}],"key":"WAM39Ss5jY"},{"type":"heading","depth":2,"position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"children":[{"type":"text","value":"Continuous Random Variables","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"ChmaGJK82L"}],"identifier":"continuous-random-variables","label":"Continuous Random Variables","html_id":"continuous-random-variables","implicit":true,"key":"wsxauRkVR3"},{"type":"paragraph","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"children":[{"type":"text","value":"The probability distribution of a continuous random variable is represented by a probability density curve. The proba