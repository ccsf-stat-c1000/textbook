{"version":3,"kind":"Article","sha256":"7f918e2d2689af3c1267825bcb5c472bfc4c751713ced26d660144de6d50f7ac","slug":"pages.m04-wrap-up-distributions","location":"/pages/037-m04-wrap-up-distributions.md","dependencies":[],"frontmatter":{"title":"Wrap-Up (Distributions)","content_includes_title":false,"authors":[{"nameParsed":{"literal":"Shawn Wiggins","given":"Shawn","family":"Wiggins"},"name":"Shawn Wiggins","affiliations":["City College of San Francisco"],"id":"contributors-myst-generated-uid-0"}],"license":{"content":{"id":"CC-BY-4.0","url":"https://creativecommons.org/licenses/by/4.0/","name":"Creative Commons Attribution 4.0 International","free":true,"CC":true}},"affiliations":[{"id":"City College of San Francisco","name":"City College of San Francisco"}],"numbering":{"title":{"offset":2}},"exports":[{"format":"md","filename":"037-m04-wrap-up-distributions.md","url":"/build/037-m04-wrap-up-dist-e760511785f0f2b2d2390edb663c76e7.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"You have now completed the module on examining distributions, which is the first of two modules within the EDA unit. You’ve seen how, by using graphs and numbers, we can bring to light all the information that is stored in the data about the variable of interest. Another important point is that graphs and numbers are powerful only when accompanied by their interpretation in the context of the problem. You are now ready to practice your knowledge by going through your first StatTutor exercise.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"ek2UhxQ3hD"}],"key":"CrFpdoqfJc"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"One of the first few screens in StatTutor will have a link to download the dataset for this StatTutor exercise. When you click that link, a pop-up window will appear asking if you want to open or save the file. Make sure you click “Save,” which will allow you to save the file to your hard drive. Then find the downloaded file and double-click it to open it if you’re using R, StatCrunch, Minitab, or Excel, or transfer it to your calculator if you’re using the TI Calculator.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"csrVa422sy"}],"key":"Epe6NCMc1t"},{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Note","key":"FVy2n7HmBQ"}],"key":"pLIEWoQKt6"},{"type":"code","lang":"","value":"**Lab**\n\nDrinking Habits and Integrity of College Students\n\n*(Interactive activity — available in the OLI platform)*","position":{"start":{"line":8,"column":1},"end":{"line":12,"column":1}},"key":"tchIev9HZ9"}],"key":"FxMv6Kf37n"},{"type":"heading","depth":2,"position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"End of Section Questions","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"GDicsNOSrD"}],"identifier":"end-of-section-questions","label":"End of Section Questions","html_id":"end-of-section-questions","implicit":true,"key":"ahmtItG2Ef"},{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Note","key":"WWflRZbFVF"}],"key":"oPCu29mr6W"},{"type":"code","lang":"","value":"**My Response**\n\nAbout Distributions\n\n*(Interactive activity — available in the OLI platform)*","position":{"start":{"line":18,"column":1},"end":{"line":22,"column":1}},"key":"mnF7j2RhBb"}],"key":"fseP8rey0a"}],"key":"RZEebLCuvj"}],"key":"N6ZMhBlbUE"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Standard Deviation (3 of 3)","url":"/pages/m04-standard-deviation-3-of-3","group":"Unit 2: Exploratory Data Analysis"},"next":{"title":"Examining Relationships","short_ti