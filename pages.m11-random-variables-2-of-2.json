":14,"column":1},"end":{"line":14,"column":1}},"key":"ZIhD6olSCv"}],"key":"k8wXiq7g3v"}],"key":"VpkhCN8cRh"}],"key":"Rnj9A6xJBq"},{"type":"list","ordered":true,"start":2,"spread":false,"position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"On the other hand, there are some variables which are discrete in nature, but take so many distinct possible values that it will be much easier to treat them as continuous rather than discrete.","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"qkxagXTvcm"}],"key":"ch0worFUjv"}],"key":"SB8kYZ45jO"}],"key":"MBTdMmXDfC"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":16,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"the IQ of a randomly chosen person","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"Ju2cO4ZkTv"}],"key":"YJPJmcgA3D"}],"key":"izuRsRCOMC"},{"type":"listItem","spread":true,"position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"the SAT score of a randomly chosen student","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"sTKzeiFccg"}],"key":"wm6iVBuvU2"}],"key":"aa2F64xhpi"},{"type":"listItem","spread":true,"position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"the annual salary of a randomly chosen CEO, whether rounded to the nearest dollar or the nearest cent","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"zeMTGt3c6E"}],"key":"Xe0eQ8eojY"}],"key":"P7w45Y4HUa"}],"key":"VRShcxazkf"},{"type":"list","ordered":true,"start":3,"spread":false,"position":{"start":{"line":19,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Sometimes we have a discrete random variable but do not know the extent of its possible values. For example: How many accidents will occur in a particular intersection this month? We may know from previously collected data that this number is from 0-5. But, 6, 7, or more accidents could be possible.","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"EHfVGB2bxi"}],"key":"XAAFJeaCKg"}],"key":"icpIZFmxVB"},{"type":"listItem","spread":true,"position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"A good rule of thumb is that ","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"xlLghIGfYF"},{"type":"emphasis","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"text","value":"discrete","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"TAESBmg4qQ"}],"key":"tiqryc3uSI"},{"type":"text","value":" random variables are things we ","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"Cms8CUy2zS"},{"type":"emphasis","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"text","value":"count","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"zZFicdb7Cw"}],"key":"JnRQC9Ox3F"},{"type":"text","value":", while ","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"bTijOlRCt8"},{"type":"emphasis","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"text","value":"continuous","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"mydnThlvDE"}],"key":"tbBVvmEmN1"},{"type":"text","value":" random variables are things we ","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"hCW2uDikFT"},{"type":"emphasis","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"text","value":"measure","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"NAY0KJvh6q"}],"key":"nAxIW2MTxb"},{"type":"text","value":".","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"L7PF7Bwd5m"}],"key":"zXxiZSvrL4"}],"key":"NTj1XWhmcY"}],"key":"ivqWsFPlJC"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":21,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"We counted the number of tails and the number of ears with earrings. These were discrete random variables.","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"s8IiVudZ56"}],"key":"SF9soSWH0a"}],"key":"AIVQEWTtKs"},{"type":"listItem","spread":true,"position":{"start":{"line":22,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"We measured the weight of the lightweight boxer. This was a continuous random variable.","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"baLDw2k8U8"}],"key":"pdILkplXLc"}],"key":"D0VNKAw77r"}],"key":"XSTKWXst4j"},{"type":"paragraph","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"text","value":"Often we can have a subject matter for which we can collect data that could involve a discrete or a continuous random variable, depending on the information we wish to know.","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"key":"abI1nDJGdD"}],"key":"i9Wptmh5Pm"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Example: Soft Drinks","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"key":"R9YPg3GMvP"}],"key":"c505XAOKsk"},{"type":"code","lang":"","value":"Suppose we want to know *how many days per week you drink a soft drink*. The sample space would be S = { 0, 1, 2, 3, 4, 5, 6, 7 }. There are a finite number of values for this variable. This would be a discrete random variable.\n\nInstead, suppose we want to know *how many ounces of soft drinks you consume per week*. Even if we round to the nearest ounce, the answer is a measurement. Thus, this would be a continuous random variable.","position":{"start":{"line":27,"column":1},"end":{"line":29,"column":1}},"key":"MVNHaZraDD"}],"key":"Xn3UcMQd4i"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Example: x-bar","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"key":"iRZYEBjIgP"}],"key":"sw44N45Jci"},{"type":"code","lang":"","value":"Suppose we are interested in the weights of all males. We take a random sample and get the mean for that sample, namely $\\bar{x}$. We then take another random sample (with the same sample size) and get another $\\bar{x}$.\n\nWe would expect the values of the $\\bar{x}$s from these two samples to be different, but pretty close in value.\n\nEach time we take a sample we'll get a different $\\bar{x}$. We will take lots of samples and thus get many $\\bar{x}$s.\n\nThe value of $\\bar{x}$ from these repeated samples is a random variable. Since it can take on any value within an interval of possible male weights it is a continuous random variable.","position":{"start":{"line":33,"column":1},"end":{"line":39,"column":1}},"key":"dS4hkPWaF8"}],"key":"kz9TzV1dZQ"},{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Note","key":"gwPFHHyxWV"}],"key":"tpg1m4x5cm"},{"type":"code","lang":"","value":"**Did I Get This?**\n\n*(Interactive activity — available in the OLI platform)*","position":{"start":{"line":43,"column":1},"end":{"line":45,"column":1}},"key":"ofPRXrTieR"}],"key":"JjVaHUNR9W"},{"type":"paragraph","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"children":[{"type":"text","value":"We devote a great deal of attention to random variables, since random variables and the probabilities that are associated with them play a vital role in the theory behind statistical inference, our ultimate goal in this course.","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"key":"xkvHIclMFi"}],"key":"iFwLJd430e"},{"type":"paragraph","position":{"start":{"line":50,"column":1},"end":{"line":50,"column":1}},"children":[{"type":"text","value":"This module is organized in two parts; one on discrete random variables, and one on continuous. We’ll start with discrete.","position":{"start":{"line":50,"column":1},"end":{"line":50,"column":1}},"key":"tXmbxNqIfV"}],"key":"JmVgiHgk4m"}],"key":"niOzdFKg0l"}],"key":"EupZypP17U"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Random Variables (1 of 2)","short_title":"Module 11: Random Variables","url":"/pages/m11-random-variables-1-of-2","group":"Unit 4: Probability"},"next":{"title":"Discrete Random Variables","url":"/pages/m11-discrete-random-variables","group":"Unit 4: Probability"}}},"domain":"http://localhost:3002"}