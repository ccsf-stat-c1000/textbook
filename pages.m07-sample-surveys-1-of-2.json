{"version":3,"kind":"Article","sha256":"7b3f2376e941dbc0c402245378e3225c157425dc4078a5272ba8cb9914465abe","slug":"pages.m07-sample-surveys-1-of-2","location":"/pages/084-m07-sample-surveys-1-of-2.md","dependencies":[],"frontmatter":{"title":"Sample Surveys (1 of 2)","content_includes_title":false,"authors":[{"nameParsed":{"literal":"Shawn Wiggins","given":"Shawn","family":"Wiggins"},"name":"Shawn Wiggins","affiliations":["City College of San Francisco"],"id":"contributors-myst-generated-uid-0"}],"license":{"content":{"id":"CC-BY-4.0","url":"https://creativecommons.org/licenses/by/4.0/","name":"Creative Commons Attribution 4.0 International","free":true,"CC":true}},"affiliations":[{"id":"City College of San Francisco","name":"City College of San Francisco"}],"numbering":{"title":{"offset":2}},"exports":[{"format":"md","filename":"084-m07-sample-surveys-1-of-2.md","url":"/textbook/build/084-m07-sample-surve-5c02c0a1e8667f424dfb5f143fe3bcb1.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Learning Objectives","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"SHr5sbBHa0"}],"key":"d6Pv9ZcNEX"},{"type":"code","lang":"","value":"- Determine how the features of a survey impact the collected data and the accuracy of the data.","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"gWRK2tSQHk"}],"key":"ySMhyxg0gm"},{"type":"heading","depth":2,"position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"Sample Surveys","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"CHYXrKeCrY"}],"identifier":"sample-surveys","label":"Sample Surveys","html_id":"sample-surveys","implicit":true,"key":"CYDYhrfp34"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"A sample survey is a particular type of observational study in which individuals report variables’ values themselves, frequently by giving their opinions. Researchers have several options to choose from when deciding how to survey the individuals involved: in person, or via telephone, Internet, or mail.","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"GuHjacGyce"}],"key":"MwjjEFVmk7"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"The following issues in the design of sample surveys will be discussed:","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"VTo4ZGwZt3"}],"key":"hXIptteJUI"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":13,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":13,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"open vs. closed questions","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"CnGp5WJHcI"}],"key":"FnZ0A6d6Yp"}],"key":"QVUBYI9NhK"},{"type":"listItem","spread":true,"position":{"start":{"line":15,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"unbalanced response options","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"N9lvnuOTkI"}],"key":"y4g8CK2Ssw"}],"key":"nvPOfWVZCO"},{"type":"listItem","spread":true,"position":{"start":{"line":17,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"leading questions","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"G9sSdSENLG"}],"key":"ZUlqZ4N53X"}],"key":"eH1I4MCmaB"},{"type":"listItem","spread":true,"position":{"start":{"line":19,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"planting ideas with questions","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"OFjpU8cZI0"}],"key":"pslHbzXPuR"}],"key":"pJtwvYzJpJ"},{"type":"listItem","spread":true,"position":{"start":{"line":21,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"complicated questions","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"iWEK84yoHg"}],"key":"K8FELwSuvJ"}],"key":"R383t25rYq"},{"type":"listItem","spread":true,"position":{"start":{"line":23,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"text","value":"sensitive questions","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"zIIkWynO9B"}],"key":"Auv8mSGLD6"}],"key":"e37SN4zGJ5"}],"key":"QUZ0jOPvNz"},{"type":"paragraph","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"children":[{"type":"text","value":"These issues are best illustrated with a variety of concrete examples.","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"H9B13IN7gT"}],"key":"MOYayTD9yu"},{"type":"paragraph","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"children":[{"type":"text","value":"Suppose you want to determine the musical preferences of all students at your university, based on a sample of students. In the ","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"MLZAP2WlBD"},{"type":"emphasis","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"children":[{"type":"text","value":"Sampling","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"Z0eiY34Xd1"}],"key":"G3hYWcr7QQ"},{"type":"text","value":" section, we discussed various ways to obtain the sample, such as taking a simple random sample from all students at the university, then contacting the chosen subjects via email to request their responses and following up with a second email to those who did not respond the first time. This method would ensure a sample that is fairly representative of the entire population of students at the university, and avoids the bias that might result from a flawed designs such as a convenience sample or a volunteer sample.","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"TtcRhs8oQK"}],"key":"rIPfASip3U"},{"type":"paragraph","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"children":[{"type":"text","value":"However, even if we managed to select a representative sample for a survey, we are not yet home free: we must still compose the survey question itself so that the information we gather from the sampled students correctly represents what is true about their musical preferences. Let us consider some possibilities:","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"key":"KBME8xP0bP"}],"key":"JhtkwbM2XZ"},{"type":"paragraph","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"children":[{"type":"emphasis","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"children":[{"type":"text","value":"Question:","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"lwvz498QoE"}],"key":"YLvMnUbI2i"},{"type":"text","value":" “What is your favorite kind of music?”","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"xdabpWjysQ"}],"key":"R43ft2CHpr"},{"type":"paragraph","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"text","value":"This is what we call an ","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"r0vVV9l7ie"},{"type":"emphasis","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"text","value":"open question","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"uEpxi8mJ0Y"}],"key":"GEHTQnzpjU"},{"type":"text","value":", which allows for almost unlimited responses. It may be difficult to make sense of all the possible categories and subcategories of music that survey respondents could come up with. Some may be more general than what you had in mind (“I like modern music the best”) and others too specific (“I like Japanese alternative electronic rock by Cornelius”). Responses are much easier to handle if they come from a","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"aXEOu0zupV"},{"type":"emphasis","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"text","value":"closed question:","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"Hgi8LO6Rry"}],"key":"LQvp4AXT5G"}],"key":"vMS5irUkgP"},{"type":"paragraph","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"children":[{"type":"emphasis","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"children":[{"type":"text","value":"Question:","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"XcsuXd3f8l"}],"key":"GtKGe0Cvip"},{"type":"text","value":" Which of these types of music do you prefer: classical, rock, pop, or hip-hop?","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"yR2CMf2EYq"}],"key":"VIUXpBf4P0"},{"type":"paragraph","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"children":[{"type":"text","value":"What will happen if a respondent is asked the question as worded above, and he or she actually prefers jazz or folk music or gospel? He or she may pick a second-favorite from the options presented, or try to pencil in the real preference, or may just not respond at all. Whatever the outcome, it is likely that overall, the responses to the question posed in this way will not give us very accurate information about general music preferences. If a closed question is used, then great care should be taken to include all the reasonable options that are possible, including “not sure.” Also, in case an option was overlooked, “other:___________” should be included for the sake of thoroughness.","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"key":"iJqnuuDWz1"}],"key":"VslFCn4fdm"},{"type":"paragraph","position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"children":[{"type":"text","value":"Many surveys ask respondents to assign a rating to a variable, such as in the following:","position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"key":"VasuCRSlyL"}],"key":"aF14tPGJWb"},{"type":"paragraph","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"children":[{"type":"emphasis","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"children":[{"type":"text","value":"Question:","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"key":"kfW4YiGWjs"}],"key":"fGz7K97rDt"},{"type":"text","value":" How do you feel about classical music? Circle one of these: I love it, I like it very much, I like it, I don’t like it, I hate it.","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"key":"bzcU294muL"}],"key":"XIumrwggRH"},{"type":"paragraph","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"children":[{"type":"text","value":"Notice that the options provided are rather “top-heavy,” with three favorable options vs. two unfavorable. If someone feels somewhat neutral, they may opt for the middle choice, “I like it,” and a summary of the survey’s results would distort the respondents’ true opinions.","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"key":"lWjl91qImR"}],"key":"j1XXHVLLGb"},{"type":"paragraph","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"children":[{"type":"text","value":"Some survey questions are either deliberately or unintentionally biased towards certain responses:","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"wob3ORpnr6"}],"key":"NqtUPVJNIt"},{"type":"paragraph","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"children":[{"type":"emphasis","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"children":[{"type":"text","value":"Question:","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"oD2JuCycpb"}],"key":"Z0xtYftbeB"},{"type":"text","value":" “Do you agree that classical music is the best type of music, because it has survived for centuries and is not only enjoyable, but also intellectually rewarding? (Answer yes or no.)”","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"AG90Pg37qa"}],"key":"pM8oydRvp2"},{"type":"paragraph","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"children":[{"type":"text","value":"This sort of wording puts ideas in people’s heads, urging them to report a particular opinion. One way to test for bias in a survey question is to ask yourself, “Just from reading the question, would a respondent have a good idea of what response the surveyor is hoping to elicit?” If the answer is yes, then the question should have been worded more neutrally.","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"GVtAFzQF9S"}],"key":"FqvbnHz1B8"}],"key":"AFkxSmE3qm"}],"key":"JznoBvE9SU"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Modifications to Randomization","url":"/pages/m07-modifications-to-randomization","group":"Unit 3: Producing Data"},"next":{"title":"Sample Surveys (2 of 2)","url":"/pages/m07-sample-surveys-2-of-2","group":"Unit 3: Producing Data"}}},"domain":"http://localhost:3002"}